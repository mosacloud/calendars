# Standalone frontend image (Docker `frontend-production` stage).
# When deployed behind an external reverse proxy / ingress, that proxy
# is responsible for routing /api/* to the backend — Caddy here only
# serves static frontend assets.
#
# For the Scalingo monolith (frontend + Django + SabreDAV in one slug)
# see src/proxy/Caddyfile. The cache + handle_errors logic below is
# intentionally duplicated there; keep both in sync.

{
	auto_https off
	admin off
}

:8080 {
	root * /srv
	header X-Frame-Options DENY

	# Vite emits every bundled output under /assets/ with a
	# content-addressed hash in its filename, so the whole directory is
	# safe to cache forever. Verbatim public/ files (favicon.png, logos,
	# error-page backgrounds, …) live at the dist root and keep the
	# default revalidation behavior, so updating them in-place still
	# propagates.
	@hashed_assets path /assets/*
	header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

	# Never cache the SPA shell — clients must re-fetch index.html to
	# pick up the new bundle hashes on each deploy.
	@spa_shell path / /index.html
	header @spa_shell Cache-Control "no-cache"

	# Serve /assets/* as real files only. A miss must surface as a 404 —
	# falling back to index.html here would return HTML for a script tag
	# and crash the page with a SyntaxError when a browser cached on an
	# old deploy requests a deleted chunk.
	handle /assets/* {
		file_server
	}

	# Default: SPA fallback. Serve the file if it exists, otherwise hand
	# off to the client-side router via index.html.
	handle {
		try_files {path} /index.html
		file_server
	}

	handle_errors {
		# Asset 404s stay 404s.
		@asset_404 {
			expression `{err.status_code} == 404`
			path /assets/*
		}
		handle @asset_404 {
			respond "Not Found" 404
		}

		# Any other 404 is a client-side route the SPA should resolve.
		@spa_404 expression `{err.status_code} == 404`
		handle @spa_404 {
			rewrite * /index.html
			file_server
		}
	}
}

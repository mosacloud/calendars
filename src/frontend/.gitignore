# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# pnpm / corepack / TanStack runtime caches. The dev container's HOME is
# this bind-mounted dir, so these land here; this entry also keeps oxlint
# (which runs inside the container and only sees this .gitignore) from
# scanning them.
/.cache
/.local
/.npm
/.pnpm-store
/.tanstack
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# build output
/dist
bundle-stats.html

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*

# typescript
*.tsbuildinfo

# generated route tree
src/routes.gen.ts

certificates

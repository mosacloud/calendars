#!/usr/bin/env bash

source "$(dirname "${BASH_SOURCE[0]}")/_config.sh"

# Bring up the dedicated test SabreDAV instance. It uses a separate
# Postgres database (caldav_test) so tests never touch the developer's
# local CalDAV data. The service has an HTTP healthcheck; backend-test
# depends on it via `condition: service_healthy` so pytest only starts
# once Apache is accepting connections.
_docker_compose up -d caldav-test

# Use the dedicated backend-test compose service so tests don't inherit
# env.d/development/backend.local. The Test settings class is selected
# via DJANGO_CONFIGURATION=Test set on the service itself.
_dc_run \
    --name backend-test \
    backend-test \
    pytest "$@"

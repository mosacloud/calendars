#!/bin/bash

set -o errexit    # always exit on error
set -o pipefail   # don't ignore exit codes when piping output

echo "-----> Running post-frontend script"

# Move the frontend build to the app root and clean up. Vite emits to
# dist/ (was out/ under Next.js static export). The slug-relative
# destination keeps the same name so bin/scalingo_run_web's
# CALENDARS_FRONTEND_ROOT default stays valid.
mkdir -p build/
mv src/frontend/dist build/frontend-out

cp src/frontend/src/features/i18n/translations.json translations.json

mv src/backend/* ./

# Download Caddy binary with checksum verification
CADDY_VERSION="2.11.2"
CADDY_SHA256="94391dfefe1f278ac8f387ab86162f0e88d87ff97df367f360e51e3cda3df56f"
CADDY_TAR="/tmp/caddy.tar.gz"
curl -fsSL -o "$CADDY_TAR" \
  "https://github.com/caddyserver/caddy/releases/download/v${CADDY_VERSION}/caddy_${CADDY_VERSION}_linux_amd64.tar.gz"
echo "${CADDY_SHA256}  ${CADDY_TAR}" | sha256sum -c -
tar -xz -C bin/ caddy < "$CADDY_TAR"
rm "$CADDY_TAR"
chmod +x bin/caddy

# Copy Caddyfile (uses {$ENV} vars natively, no ERB needed)
cp src/proxy/Caddyfile ./Caddyfile

echo "3.13" > .python-version

# --- PHP + SabreDAV setup ---
echo "-----> Installing PHP 8.5 from Ubuntu 26.04 packages"

PHP_PREFIX=".php"
DEB_DIR="/tmp/php-debs"
mkdir -p "$DEB_DIR" "$PHP_PREFIX"

# Standard Ubuntu 26.04 (Resolute) php8.5 packages — the production stack is
# scalingo-26 (Ubuntu 26.04), whose only PHP is 8.5. We just unpack PHP with
# dpkg-deb -x and rely on the stack for the shared libraries it links against
# (libxml2.so.16, libpq.so.5, libonig.so.5, libcurl.so.4, libxslt, ...), which
# are all present at the standard multiarch path. No library bundling needed.
# Source: https://launchpad.net/ubuntu/resolute/amd64/php8.5-cli
# Format: "package_name url sha256"
PHP_DEBS=(
  "php8.5-cli https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-cli_8.5.4-0ubuntu1.1_amd64.deb ed6b676240ea06d9c5672281d790f12ccd41a194582089b9cc7209e7733e1728"
  "php8.5-fpm https://archive.ubuntu.com/ubuntu/pool/universe/p/php8.5/php8.5-fpm_8.5.4-0ubuntu1.1_amd64.deb 7ca88edc71bd17fe415be91ec3b397cdf04a3b109559b616ab1577cf388c159a"
  "php8.5-common https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-common_8.5.4-0ubuntu1.1_amd64.deb 0f7c152b48931c312a371edfef0604e3ac709363207f1a01c94ffebd685d57a5"
  "php8.5-readline https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-readline_8.5.4-0ubuntu1.1_amd64.deb 358fec394d5513fd0704fe2ee429604e14b213d5f9277592a295103b1bb0f483"
  "php8.5-pgsql https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-pgsql_8.5.4-0ubuntu1.1_amd64.deb bd2d6fa4535e62230fd04331b64bebd3152882d2e70f79d7bec658e76af4fa33"
  "php8.5-xml https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-xml_8.5.4-0ubuntu1.1_amd64.deb 5de6c0a38bbae2dab75b68a0479398a43d27c61788266fb2dcf94cf0c28f5ed9"
  "php8.5-mbstring https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-mbstring_8.5.4-0ubuntu1.1_amd64.deb ccc34eeb785a7bef524ecf56a1f3ef0fccaed8f712ba2e98dafb15d34a4519af"
  "php8.5-curl https://archive.ubuntu.com/ubuntu/pool/main/p/php8.5/php8.5-curl_8.5.4-0ubuntu1.1_amd64.deb 5aa2a09b34180140e0cd8cb665be2e290be8a538e907cf548851bc59ed1f54d8"
  "php-common https://archive.ubuntu.com/ubuntu/pool/main/p/php-defaults/php-common_99ubuntu1_all.deb 2d6417a2f74686b9b23f48126131c6fc1a142d6746e5547d85353d8190aa8f8e"
)

for entry in "${PHP_DEBS[@]}"; do
  read -r pkg url sha256 <<< "$entry"
  echo "       Downloading ${pkg}"
  curl -fsSL -o "$DEB_DIR/${pkg}.deb" "$url"
  echo "${sha256}  ${DEB_DIR}/${pkg}.deb" | sha256sum -c -
done

for deb in "$DEB_DIR"/*.deb; do
  dpkg-deb -x "$deb" "$PHP_PREFIX"
done

# Detect PHP extension directory (e.g. .php/usr/lib/php/20250925)
EXT_DIR_NAME="$(ls -1 "$PHP_PREFIX/usr/lib/php/" | grep '^20' | head -1)"
echo "       Extension API dir: ${EXT_DIR_NAME}"
echo "       Available .so files: $(ls "$PHP_PREFIX/usr/lib/php/$EXT_DIR_NAME/" 2>/dev/null | tr '\n' ' ')"

# Build a single php.ini that sets extension_dir (relative to /app at runtime)
# then loads every shared extension present.
# Conf.d symlinks from debs are broken (absolute paths to /etc/php/...),
# so we bypass them entirely with a self-contained ini (php is run with -n).
PHP_INI="$PHP_PREFIX/php.ini"
{
  echo "; Auto-generated PHP config"
  echo "extension_dir = /app/.php/usr/lib/php/${EXT_DIR_NAME}"
  echo ""
  # Errors go to the logs, never into the HTTP response. Without this a PHP
  # warning/deprecation (e.g. PHP 8.5 deprecations) prints into the body and
  # breaks header sending ("headers already sent"). Mirrors the dev container.
  echo "log_errors = On"
  echo "error_log = /proc/self/fd/2"
  echo "display_errors = Off"
  echo "display_startup_errors = Off"
  echo "memory_limit = 512M"
  echo ""
  for so in "$PHP_PREFIX/usr/lib/php/$EXT_DIR_NAME"/*.so; do
    [ -f "$so" ] || continue
    name="$(basename "$so")"
    if [ "$name" = "opcache.so" ]; then
      echo "zend_extension = ${name}"
    else
      echo "extension = ${name}"
    fi
  done
} > "$PHP_INI"
echo "       Generated php.ini:"
cat "$PHP_INI" | sed 's/^/         /'

# Create a build-time copy with the current path (not /app)
BUILD_INI="/tmp/php-build.ini"
sed "s|/app/.php|$PWD/.php|" "$PHP_INI" > "$BUILD_INI"

# Create php wrapper (uses /app php.ini at runtime)
cat > bin/php << 'WRAPPER'
#!/bin/bash
DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec "$DIR/.php/usr/bin/php8.5" -c "$DIR/.php/php.ini" -n "$@"
WRAPPER
chmod +x bin/php

# For build-time, verify with the build-time ini
echo "-----> PHP version: $("$PHP_PREFIX/usr/bin/php8.5" -n -c "$BUILD_INI" -v | head -1)"
echo "-----> PHP modules: $("$PHP_PREFIX/usr/bin/php8.5" -n -c "$BUILD_INI" -m | tr '\n' ' ')"

# Download Composer with integrity verification and install SabreDAV dependencies
echo "-----> Installing SabreDAV dependencies"
COMPOSER_VERSION="2.9.5"
COMPOSER_SHA256="c86ce603fe836bf0861a38c93ac566c8f1e69ac44b2445d9b7a6a17ea2e9972a"
curl -fsSL -o bin/composer.phar \
  "https://getcomposer.org/download/${COMPOSER_VERSION}/composer.phar"
echo "${COMPOSER_SHA256}  bin/composer.phar" | sha256sum -c -
cp -r src/caldav sabredav
cd sabredav
"../$PHP_PREFIX/usr/bin/php8.5" -n -c "$BUILD_INI" ../bin/composer.phar install \
  --no-dev --optimize-autoloader --no-interaction
cd ..
